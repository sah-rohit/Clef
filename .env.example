# BACKEND URL (From Convex Dashboard)
VITE_CONVEX_URL=https://your-deployment-name.convex.cloud

# AI ENGINE KEY — set this in Convex, not here:
#   npx convex env set GROQ_API_KEY <your_key>
# GROQ_API_KEY is a server-side secret and must NOT be committed to source control.
# GROQ_API_KEY=your_key_here
